name: App

on:
  push:
    branches: [ "main" ]
  pull_request:
    branches: [ "main" ]

permissions:
  security-events: write
  packages: write
  contents: read

jobs:
  CODE_CI:
    secrets: inherit
    uses: ARYAVERS/aryavars-ci/.github/workflows/ci.yaml@main
    with:
      classification: "app-api"

